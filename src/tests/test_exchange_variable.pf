module test_exchange_variable
  use funit
  use mo_exchange_type, only: var_dp, var2d_dp
  use mo_kind, only: dp, i8

  implicit none

  private

  public :: test_var_dp_contract, test_var_dp_alias, test_var2d_dp_contract

contains

  @test
  subroutine test_var_dp_contract()
    type(var_dp) :: variable
    type(var_dp) :: dynamic_source
    real(dp), target :: local(3)
    integer(i8), allocatable :: var_shape(:)

    local = [1.0_dp, 2.0_dp, 3.0_dp]
    variable = var_dp(name="test_scalar")

    @assertEqual(.false., variable%available(), message='var_dp starts unavailable')
    @assertEqual(.true., variable%available(owned=.true.), message='var_dp owned availability')

    call variable%publish_local("test", local)
    @assertEqual(.true., variable%provided, message='var_dp publish_local sets provided')
    @assertEqual(.true., variable%available(), message='var_dp publish_local makes available')
    @assertEqual(2.0_dp, variable%data(2), message='var_dp publish_local points to local data')

    var_shape = variable%data_shape()
    @assertEqual([3_i8], var_shape, message='var_dp data_shape')
    call variable%require("test", .true., [3_i8])
    @assertEqual(.true., variable%required, message='var_dp require marks required')

    call variable%clear(.false.)
    @assertEqual(.true., variable%provided, message='var_dp clear without ownership keeps provided')
    call variable%clear(.true.)
    @assertEqual(.false., variable%provided, message='var_dp owned clear resets provided')
    @assertEqual(.false., variable%has_data(), message='var_dp owned clear nullifies data')
    @assertEqual(.true., variable%required, message='var_dp owned clear keeps required')

    dynamic_source = var_dp(name="dynamic_source")
    dynamic_source%provided = .true.
    call dynamic_source%require("test", .true., check_data=.false.)
    @assertEqual(.true., dynamic_source%required, message='var_dp require can validate source only')
    @assertEqual(.false., dynamic_source%has_data(), message='var_dp source-only require does not need data')
  end subroutine test_var_dp_contract

  @test
  subroutine test_var_dp_alias()
    type(var_dp) :: source
    type(var_dp) :: alias
    real(dp), target :: local(3)

    local = [1.0_dp, 2.0_dp, 3.0_dp]
    source = var_dp(name="source")
    alias = var_dp(name="alias")

    call source%publish_local("test", local)
    call alias%publish_alias("test", source)
    local(1) = 9.0_dp

    @assertEqual(.true., alias%provided, message='var_dp publish_alias sets provided')
    @assertEqual(9.0_dp, alias%data(1), message='var_dp publish_alias points to source data')
    call alias%expect_handoff("test", .true., [3_i8])
    @assertEqual(.true., alias%required, message='var_dp expect_handoff marks required')
  end subroutine test_var_dp_alias

  @test
  subroutine test_var2d_dp_contract()
    type(var2d_dp) :: variable
    real(dp), target :: local(2, 3)
    integer(i8), allocatable :: var_shape(:)

    local = reshape([1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp, 5.0_dp, 6.0_dp], shape(local))
    variable = var2d_dp(name="test_layered")

    call variable%publish_local("test", local)
    @assertEqual(.true., variable%available(), message='var2d_dp publish_local makes available')
    @assertEqual(5.0_dp, variable%data(1, 3), message='var2d_dp publish_local points to local data')

    var_shape = variable%data_shape()
    @assertEqual([2_i8, 3_i8], var_shape, message='var2d_dp data_shape')
    call variable%require("test", .true., [2_i8, 3_i8])
    call variable%expect_handoff("test", .true., [2_i8, 3_i8])
    @assertEqual(.true., variable%required, message='var2d_dp expect_handoff marks required')
  end subroutine test_var2d_dp_contract

end module test_exchange_variable
