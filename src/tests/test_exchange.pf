module test_exchange
  use funit

  implicit none

  private

  public :: test_exchange_type

contains

  @test
  subroutine test_exchange_type()
    use mo_exchange_type, only: exchange_t
    use mo_datetime, only: datetime
    use mo_kind, only: i4
    type(exchange_t) :: exchange
    type(datetime) :: start_date

    start_date = datetime(2025, 8, 4, 0, 0)
    call exchange%init(start_date)

    @assertTrue(exchange%current_time == start_date, message='exchange: check start date')
    @assertTrue(exchange%time_step == 0_i4, message='exchange: check time step')
  end subroutine test_exchange_type

end module test_exchange
