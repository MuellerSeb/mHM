!******************************************************************************************
! NEW MRM v6 NMLs
!******************************************************************************************
&mainconfig
/
&mainconfig_mhm_mrm
  mrm_file_RestartIn(1)     = "test_domain/restart/mRM_restart_001.nc"
  resolution_Routing(1) = 24000
  timestep = 1
/
&time_periods
  warming_Days(1)    = 0
  eval_Per(1)%yStart = 1990
  eval_Per(1)%mStart = 01
  eval_Per(1)%dStart = 01
  eval_Per(1)%yEnd   = 1993
  eval_Per(1)%mEnd   = 12
  eval_Per(1)%dEnd   = 31
/
&processSelection
  processCase(1) = 1
  processCase(2) = 1
  processCase(3) = 1
  processCase(4) = 1
  processCase(5) = 0
  processCase(6) = 1
  processCase(7) = 1
  !> routing
  !> 0 - deactivated
  !> 1 - Muskingum approach
  !> 2 - adaptive timestep, constant celerity
  !> 3 - adaptive timestep, spatially varying celerity
  processCase(8) = 3
  processCase(9) = 1
  processCase(10) = 0
  processCase(11) = 0
/
&mrm_main
! default="daily", help="Output frequency: hourly, daily (default), monthly, yearly, once")
out_frequency = 'daily'
! has_value=.true.,  help="Routing grid resolution. By default: Resolution of runoff.")
level11 = 4000
! "Minimum river level size to route in parallel with OpenMP. By default: threads * 8
omp_min = 1
! Level order for parallel routing starting from river root
parallel_rout = .false.
read_restart = .true.
write_restart = .true.
/

&mrm_dirs
!
scc_file = "src/tests/files/scc_gauges.nc"
fdir_file = "src/tests/files/fdir.asc" ! "src/tests/files/input.nc"
dem_file = "src/tests/files/dem.asc"
slope_file = "src/tests/files/slope.asc"
out_file = "out_test.nc"
node_out_file = "out_node_test.nc"
/

&runoff_input
! reading chunk size: off (default - 0), monthly (1), yearly (2), once (not sure what this should be)
chunk = 'monthly'
runoff_file = "src/tests/files/runoff.nc"
/

