&config_project
  n_domains = 1
/

&config_processes
  routing = 2
  temperature_routing = 1
/

&config_time
  sim_start(1)  = "1990-01-01 00:00"
  eval_start(1) = "1990-01-01 00:00"
  sim_end(1)    = "1990-01-03 00:00"
/

&config_input
  runoff_path(1) = "src/tests/files/runoff.nc"
  runoff_var(1)  = "Q"
  fdir_path(1)   = "src/tests/files/input.nc"
  slope_path(1)  = "src/tests/files/input.nc"
  meteo_mask_path(1) = "test_domain/input/meteo/mask.nc"
  pre_path(1)    = "test_domain/input/meteo/pre/pre.nc"
  ssrd_path(1)   = "test_domain/input/meteo/ssrd.nc"
  strd_path(1)   = "test_domain/input/meteo/strd.nc"
  tann_path(1)   = "test_domain/input/meteo/tavg/tann.nc"
/

&config_meteo
/

&config_mhm
  resolution(1) = 24000.0
/

&config_mrm
  resolution(1)     = 2000.0
  max_route_step(1) = 3600
  output_path(1)    = "mrm_rivertemp_output.nc"
  diagnostics_path(1) = "mrm_rivertemp_diagnostics.nc"
/
