&config_project
  n_domains      = 1
/

&config_processes
  routing        = 2
/

&config_time
  sim_start(1)   = "1990" ! "1990-01-01 00:00"
  eval_start(1)  = "1990" ! "1990-01-01 00:00"
  sim_end(1)     = "1994" ! "1994-01-01 00:00"
/

&config_input
  runoff_path(1) = "src/tests/files/runoff.nc"
  runoff_var(1)  = "Q"
  fdir_path(1)   = "src/tests/files/input.nc"
  slope_path(1)   = "src/tests/files/input.nc"
/

&config_mrm
  resolution(1)  = 2000.0
  max_route_step(1) = 3600 ! [s] truncate routing steps to 1 hour
  output_path(1) = "mrm_output.nc"
  ! output_node_path(1) = "mrm_output_node.nc"
  ! scc_gauges_path(1) = "src/tests/files/scc_gauges.nc"
  diagnostics_path(1) = "mrm_diagnostics.nc"
/
