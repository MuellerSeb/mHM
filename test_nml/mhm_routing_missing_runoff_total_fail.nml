&config_project
  n_domains = 1
/

&config_processes
  interception = -1
  snow = -1
  routing = 2
/

&config_time
  sim_start(1)  = "1990-01-01 00:00"
  eval_start(1) = "1990-01-01 00:00"
  sim_end(1)    = "1990-01-03 00:00"
/

&config_input
  slope_path(1)     = "src/tests/files/input.nc"
  aspect_path(1)    = "test_domain/input/morph/aspect.asc"
  geo_class_path(1) = "test_domain/input/morph/geology_class.asc"
  soil_class_path(1)= "test_domain/input/morph/soil_class.asc"
  lai_class_path(1) = "test_domain/input/morph/LAI_class.asc"
  fdir_path(1)      = "src/tests/files/input.nc"
  meteo_mask_path(1)= "test_domain/input/meteo/mask.nc"
  pre_path(1)       = "test_domain/input/meteo/pre/pre.nc"
/

&config_meteo
/

&config_mpr
  soil_db_mode(1)          = 0
  n_horizons(1)            = 2
  tillage_depth(1)         = 200
  soil_depth(1, 1)         = 200
  fracSealed_cityArea(1)   = 0.6
  land_cover_path(1)       = "src/tests/files/lc_static.nc"
  land_cover_var(1)        = "land_cover"
  lai_time_step(1)         = 0
  soil_lut_path(1)         = "test_domain/input/morph/soil_classdefinition.txt"
  geo_lut_path(1)          = "test_domain/input/morph/geology_classdefinition.txt"
  lai_lut_path(1)          = "test_domain/input/morph/LAI_classdefinition.txt"
/

&config_mhm
  resolution(1) = 4000.0
/

&config_mrm
  resolution(1) = 2000.0
  max_route_step(1) = 3600
/
